# Verotin Configuration Example
# Copy this to .env.local and adjust values as needed

# Spring Profile: dev (with fixture ingest), default (prod without)
SPRING_PROFILES_ACTIVE=dev

# PostgreSQL (matches docker-compose.yml)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/verotin
SPRING_DATASOURCE_USERNAME=verotin
SPRING_DATASOURCE_PASSWORD=verotin

# Ollama (local embedding and chat models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=mxbai-embed-large
OLLAMA_CHAT_MODEL=llama3
OLLAMA_EMBEDDING_DIMENSIONS=1024

# Server
SERVER_PORT=8080

# Logging
LOGGING_LEVEL_FI_VEROTIN=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_WEB_REACTIVE=INFO

# Fixture ingest (dev profile only)
VEROTIN_FIXTURES_INGEST_ON_STARTUP=true

